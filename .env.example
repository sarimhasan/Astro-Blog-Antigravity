# Turso Database Connection
# Follow these steps to connect to Turso for production:
# 1. Install Turso CLI: https://docs.turso.tech/cli/installation
# 2. Login: turso auth login
# 3. Create a database: turso db create my-blog
# 4. Get URL: turso db show my-blog
# 5. Create token: turso db tokens create my-blog
# 6. Fill in the values below
# 7. Push schema: astro db push --remote

ASTRO_DB_REMOTE_URL=libsql://your-database.turso.io
ASTRO_DB_APP_TOKEN=your-token-here
