      <a href="/journal"                class="transition-colors hover:text-[var(--primary)] cursor-crosshair">Journal</a>
      <a href="/category/philosophy"    class="transition-colors hover:text-[var(--primary)] cursor-crosshair">Philosophy</a>
      <a href="/category/science"       class="transition-colors hover:text-[var(--primary)] cursor-crosshair">Science</a>
      <a href="/category/thoughts"      class="transition-colors hover:text-[var(--primary)] cursor-crosshair">Thoughts</a>
      <a href="/category/miscellaneous" class="transition-colors hover:text-[var(--primary)] cursor-crosshair">Miscellaneous</a>
