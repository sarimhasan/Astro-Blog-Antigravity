---
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="newsletter">
      <h3 class="newsletter-title">Join the Dialogue</h3>
      <p class="newsletter-desc">Sign up your email and receive our newsletter on latest ideas.</p>
      <form class="newsletter-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="Email" required class="newsletter-input" />
        <button type="submit" class="newsletter-btn">Subscribe</button>
      </form>
    </div>
    
    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <div class="footer-brand">
        <a href="/" class="footer-home">Home</a>
      </div>
      <div class="footer-cats">
        <a href="/category/philosophy">Philosophy</a>
        <a href="/category/science">Science</a>
        <a href="/category/nature">Nature</a>
        <a href="/category/travel">Travel</a>
      </div>
      <div class="footer-quote">
        "Exploring the cosmos without<br/>and the universe within."<br/><span class="quote-author">— Elon</span>
      </div>
    </div>
    
    <div class="footer-copyright">
      &copy; Copyright TM 2024. All rights reserved
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #2B302C;
    color: #F5F4EF;
    padding: 80px 0 30px;
    margin-top: 100px;
  }
  
  .footer-container {
    max-width: 900px;
  }

  .newsletter {
    text-align: center;
    max-width: 500px;
    margin: 0 auto 60px;
  }

  .newsletter-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .newsletter-desc {
    color: #A0A5A2;
    font-size: 0.95rem;
    margin-bottom: 24px;
  }

  .newsletter-form {
    display: flex;
    gap: 12px;
  }

  .newsletter-input {
    flex-grow: 1;
    padding: 12px 20px;
    border-radius: 4px;
    border: 1px solid #4A504C;
    background: transparent;
    color: white;
    font-family: var(--font-primary);
  }

  .newsletter-input::placeholder {
    color: #7E8581;
  }

  .newsletter-btn {
    background: #D4C9A8;
    color: #2B302C;
    padding: 0 24px;
    border-radius: 4px;
    font-weight: 600;
    font-family: var(--font-primary);
    border: none;
    cursor: pointer;
    transition: filter 0.2s;
  }

  .newsletter-btn:hover {
    filter: brightness(1.05);
  }

  .footer-divider {
    height: 1px;
    background: #4A504C;
    margin-bottom: 40px;
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: 1fr 2fr 2fr;
    gap: 40px;
    margin-bottom: 60px;
    font-size: 0.9rem;
  }

  .footer-home {
    font-weight: 600;
  }

  .footer-cats {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-quote {
    color: #A0A5A2;
    font-style: italic;
    line-height: 1.6;
    text-align: right;
  }

  .quote-author {
    display: block;
    margin-top: 8px;
    font-style: normal;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  a:hover {
    opacity: 0.8;
  }

  .footer-copyright {
    text-align: left;
    font-size: 0.75rem;
    color: #7E8581;
  }

  @media (max-width: 640px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-btn {
      padding: 12px;
    }
    .footer-bottom {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-quote {
      text-align: center;
    }
    .footer-copyright {
      text-align: center;
    }
  }
</style>
