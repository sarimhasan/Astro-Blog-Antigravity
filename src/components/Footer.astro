---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-bottom">
      <div class="footer-brand">
        <a href="/" class="footer-home">Home</a>
      </div>
      <div class="footer-cats">
        <a href="/category/philosophy">Philosophy</a>
        <a href="/category/science">Science</a>
        <a href="/category/thoughts">Thoughts</a>
        <a href="/category/miscellaneous">Miscellaneous</a>
      </div>
      <div class="footer-quote">
        "Exploring the cosmos without<br/>and the universe within."<br/><span class="quote-author">— Elon</span>
      </div>
    </div>
    
    <div class="footer-copyright">
      &copy; Copyright TM 2024. All rights reserved
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #2B302C;
    color: #F5F4EF;
    padding: 80px 0 30px;
    margin-top: 100px;
  }
  
  .footer-container {
    max-width: 900px;
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: 1fr 2fr 2fr;
    gap: 40px;
    margin-bottom: 60px;
    font-size: 0.9rem;
  }

  .footer-home {
    font-weight: 600;
  }

  .footer-cats {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-quote {
    color: #A0A5A2;
    font-style: italic;
    line-height: 1.6;
    text-align: right;
  }

  .quote-author {
    display: block;
    margin-top: 8px;
    font-style: normal;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  a:hover {
    opacity: 0.8;
  }

  .footer-copyright {
    text-align: left;
    font-size: 0.75rem;
    color: #7E8581;
  }

  @media (max-width: 640px) {
    .footer-bottom {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-quote {
      text-align: center;
    }
    .footer-copyright {
      text-align: center;
    }
  }
</style>
