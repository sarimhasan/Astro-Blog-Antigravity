---
interface Props {
  coverImage?: string;
}
const { coverImage = '/images/trending-climate.jpg' } = Astro.props;
---

<section class="hero-section">
  <div class="hero-bg">
    <img src={coverImage} alt="Nature background" class="hero-img" loading="eager" />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content">
    <h1 class="hero-quote">"I don't let my education<br/>get in the way of my learning."</h1>
    <p class="hero-attribution">— Mark Twain</p>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 80px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30,35,32,0.5);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 40px;
    max-width: 800px;
  }
  .hero-quote {
    font-family: var(--font-heading);
    color: white;
    font-size: 3.5rem;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 16px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }
  .hero-attribution {
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-primary);
    font-size: 1.1rem;
    font-style: italic;
    letter-spacing: 0.05em;
  }
  @media (max-width: 768px) {
    .hero-quote {
      font-size: 2.2rem;
    }
  }
</style>
