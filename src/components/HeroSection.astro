---
interface Props {
  coverImage?: string;
}
const { coverImage = '/images/trending-climate.jpg' } = Astro.props;
---

<section class="relative mb-20 min-h-[460px] overflow-hidden rounded-2xl">
  <img src={coverImage} alt="Nature background" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-black/45"></div>
  <div class="relative z-10 mx-auto max-w-[800px] px-6 py-20 text-center">
    <h1 class="font-['Newsreader'] text-[clamp(2.2rem,6vw,3.7rem)] leading-[1.15] text-white [text-shadow:0_2px_10px_rgba(0,0,0,0.3)]">I do not let my education get in the way of my learning.</h1>
    <p class="mt-4 text-[1rem] italic tracking-[0.05em] text-white/90">Mark Twain</p>
  </div>
</section>
