---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  slug: string;
  excerpt: string;
  coverImage: string;
  categoryName: string;
  categorySlug: string;
  authorName: string;
  readTime: string;
}

const { title, slug, coverImage, categoryName, categorySlug, readTime } = Astro.props;
const dateStr = 'Apr 3, 2024';
---

<article class="overflow-hidden rounded-xl border border-[#d7d0c3] bg-[#f8f6f1] shadow-[0_4px_12px_rgba(20,19,18,0.06)] transition hover:-translate-y-1 hover:shadow-[0_12px_24px_rgba(20,19,18,0.1)]">
  <a href={`/${slug}`} class="block h-48 overflow-hidden">
    <img src={coverImage} alt={title} class="h-full w-full object-cover transition duration-500 hover:scale-[1.03]" loading="lazy" />
  </a>

  <div class="flex h-[calc(100%-12rem)] min-h-[220px] flex-col p-5">
    <div class="mb-3">
      <CategoryBadge name={categoryName} slug={categorySlug} />
    </div>

    <a href={`/${slug}`} class="block grow">
      <h3 class="font-['Newsreader'] text-[1.38rem] font-bold leading-[1.3] text-[#171615]">{title}</h3>
      <p class="mt-2 line-clamp-2 text-[0.95rem] leading-6 text-[#504b45]">{excerpt}</p>
    </a>

    <div class="mt-5 flex items-center justify-between border-t border-[#e4ded2] pt-3 font-['IBM Plex Mono'] text-[0.7rem] uppercase tracking-[0.08em] text-[#7e776e]">
      <span>{dateStr}</span>
      <span>{readTime}</span>
    </div>
  </div>
</article>
