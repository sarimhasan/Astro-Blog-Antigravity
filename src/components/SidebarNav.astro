---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { label: 'Journal', href: '/journal' },
  { label: 'Philosophy', href: '/category/philosophy' },
  { label: 'Science', href: '/category/science' },
  { label: 'Thoughts', href: '/category/thoughts' },
  { label: 'Miscellaneous', href: '/category/miscellaneous' },
];

const isActive = (href: string) => {
  if (href === '/journal') {
    return currentPath === '/journal' || currentPath === '/';
  }

  return currentPath.startsWith(href);
};
---

<div class="mb-6 rounded-[2.2rem] bg-[color:rgba(245,244,235,0.84)] p-3 backdrop-blur-xl lg:hidden">
  <p class="px-2 font-['Space_Grotesk'] text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-[var(--on-surface)]">Navigation</p>
  <nav class="mt-2 flex gap-2 overflow-x-auto pb-1" aria-label="Primary navigation mobile">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'shrink-0 rounded-full px-4 py-2.5 font-[\'Space_Grotesk\'] text-[0.72rem] font-semibold uppercase tracking-[0.12em] transition',
          isActive(item.href)
            ? 'bg-[var(--nebula-gradient)] text-white shadow-[0_10px_24px_rgba(117,78,185,0.34)]'
            : 'bg-white/60 text-[var(--on-surface-soft)] hover:bg-white hover:text-[var(--on-surface)]',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</div>

<aside class="relative hidden overflow-hidden rounded-[2.6rem] bg-[var(--surface-container)] px-5 py-7 shadow-[0_16px_38px_rgba(56,56,51,0.09)] lg:block lg:min-h-[calc(100vh-2rem)] lg:sticky lg:top-4">
  <div class="pointer-events-none absolute -left-9 top-24 h-48 w-48 rounded-[44%_56%_67%_33%/45%_39%_61%_55%] bg-[color:rgba(183,142,254,0.2)]"></div>
  <div class="pointer-events-none absolute -bottom-10 right-[-18px] h-44 w-44 rounded-[55%_45%_39%_61%/46%_53%_47%_54%] bg-[color:rgba(255,214,122,0.24)]"></div>

  <div class="relative z-10">
    <p class="font-['Space_Grotesk'] text-[0.86rem] font-bold uppercase tracking-[0.12em] text-[var(--on-surface)]">Operator_01</p>
    <p class="mt-1 font-['Space_Grotesk'] text-[0.72rem] uppercase tracking-[0.1em] text-[var(--on-surface)]">Uptime: 18Y | Status: Learning...</p>

    <nav class="mt-9 flex flex-col gap-3" aria-label="Primary navigation desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-full px-4 py-3 font-[\'Space_Grotesk\'] text-[0.84rem] font-semibold uppercase tracking-[0.1em] transition',
            isActive(item.href)
              ? 'bg-[var(--nebula-gradient)] text-white shadow-[0_10px_24px_rgba(117,78,185,0.35)]'
              : 'bg-white/70 text-[var(--on-surface)] hover:bg-white hover:text-[var(--on-surface)]',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

  </div>
</aside>
