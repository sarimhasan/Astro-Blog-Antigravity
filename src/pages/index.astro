---
/**
 * Homepage Component index.astro
 * The entry point of the blog. Displays a hero section with a featured post,
 * followed by a grid of latest reflections and an author introduction.
 */
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import RecentPostCard from '../components/RecentPostCard.astro';
import ThemeIcons from '../components/ThemeIcons.astro';
import AboutAuthor from '../components/AboutAuthor.astro';
import { getCollection } from 'astro:content';

/**
 * Data Fetching:
 * We fetch all entries from the 'posts' collection managed by Keystatic.
 * The posts are mapped and reversed so the most recent ones appear first.
 */
const _allPosts = await getCollection('posts');
const allPosts = _allPosts.map(p => ({ slug: p.slug, ...p.data })).reverse();

// Define category mapping for display names
const CATEGORIES: Record<string, string> = {
  philosophy: 'Philosophy',
  science: 'Science',
  thoughts: 'Thoughts',
  miscellaneous: 'Miscellaneous',
};

/**
 * Logic for Latest Reflections:
 * Display the first 4 posts in the grid.
 */
const recentPosts = allPosts.slice(0, 4);
---

<MainLayout title="The Wandering Mind">
  <Header />

  <main class="container" style="padding-top: 32px; padding-bottom: 32px;">
    <!-- Static Hero Section with Quote -->
    <HeroSection />

    <!-- Latest Reflections Grid Section -->
    <section class="latest-reflections">
      <h2 class="section-title">Latest Reflections</h2>
      <div class="cards-grid">
        {recentPosts.map((post: any) => {
          const catName = CATEGORIES[post.category] || 'General';
          return (
            <RecentPostCard
              title={post.title}
              slug={post.slug}
              excerpt={post.excerpt}
              coverImage={post.coverImage}
              categoryName={catName}
              categorySlug={post.category}
              authorName={post.authorName}
              readTime={post.readTime}
            />
          );
        })}
      </div>
    </section>

    <!-- Visual icons/theme enhancements -->
    <ThemeIcons />

    <div class="divider"></div>

    <!-- About Author Section -->
    <AboutAuthor />
  </main>

  <Footer />
</MainLayout>

<style>
  .latest-reflections {
    margin-bottom: 80px;
  }
  
  /* Responsive grid layout for post cards */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  
  /* Aesthetic divider between sections */
  .divider {
    height: 1px;
    background: var(--border-color);
    margin: 80px 0;
    width: 60%;
    margin-left: auto;
    margin-right: auto;
  }
  
  /* Responsive Breakpoints */
  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

