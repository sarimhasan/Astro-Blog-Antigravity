---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import RecentPostCard from '../components/RecentPostCard.astro';
import ThemeIcons from '../components/ThemeIcons.astro';
import AboutAuthor from '../components/AboutAuthor.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from content collections
const _allPosts = await getCollection('posts');
const allPosts = _allPosts.map(p => ({ slug: p.slug, ...p.data }));

const CATEGORIES: Record<string, string> = {
  philosophy: 'Philosophy',
  science: 'Science',
  nature: 'Nature',
  travel: 'Travel',
};

// Get featured post (for hero background image source)
const featuredPost = allPosts.find((p: any) => p.featured) || allPosts[0];

// Get recent posts: latest 4 based on array slice logic (or just take first 4 after featured logic)
const recentPosts = allPosts.filter((p: any) => p !== featuredPost).slice(0, 4);
---

<MainLayout title="The Wandering Mind">
  <Header />

  <main class="container" style="padding-top: 32px; padding-bottom: 32px;">
    {featuredPost && (
      <HeroSection
        slug={featuredPost.slug}
        coverImage={featuredPost.coverImage}
      />
    )}

    <section class="latest-reflections">
      <h2 class="section-title">Latest Reflections</h2>
      <div class="cards-grid">
        {recentPosts.map((post: any) => {
          const catName = CATEGORIES[post.category] || 'General';
          return (
            <RecentPostCard
              title={post.title}
              slug={post.slug}
              excerpt={post.excerpt}
              coverImage={post.coverImage}
              categoryName={catName}
              categorySlug={post.category}
              authorName={post.authorName}
              readTime={post.readTime}
            />
          );
        })}
      </div>
    </section>

    <ThemeIcons />

    <div class="divider"></div>

    <AboutAuthor />
  </main>

  <Footer />
</MainLayout>

<style>
  .latest-reflections {
    margin-bottom: 80px;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .divider {
    height: 1px;
    background: var(--border-color);
    margin: 80px 0;
    width: 60%;
    margin-left: auto;
    margin-right: auto;
  }
  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
