---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { formatPostDate, getFeaturedPost, mapPostEntry, sortPostsByDateDesc } from '../lib/content';

const posts        = sortPostsByDateDesc((await getCollection('posts')).map(mapPostEntry));
const featuredPost = getFeaturedPost(posts);
const recentPosts  = posts.slice(0, 3);
const gearPosts    = posts.slice(3, 6);

const intelItems = (await getCollection('intel')).map((item) => ({ slug: item.slug, ...item.data }));

// Entry count label (pad to 3 digits)
const entryCount = String(posts.length).padStart(3, '0');
---

<MainLayout
  title="Karachi And Beyond"
  description="A celestial log mapping the path from the shores of Sindh to the Martian frontier."
>

  <!-- ══════════════════════════════════════════════════
       SECTION 1 — HERO
  ═══════════════════════════════════════════════════ -->
  <section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center overflow-hidden border-b border-[#31353b]/20 px-6">
    <!-- Background layers -->
    <div class="star-map absolute inset-0 opacity-50" aria-hidden="true"></div>
    <div class="hero-glow absolute inset-0" aria-hidden="true"></div>

    <!-- Content -->
    <div class="relative z-10 text-center">
      <p class="font-['Space_Mono'] text-[0.65rem] uppercase tracking-[0.5em] text-[var(--secondary-container)]">
        --system: initialized
      </p>

      <h1 class="mt-4 font-['Space_Grotesk'] text-[clamp(4.5rem,14vw,9rem)] font-bold uppercase leading-[0.88] tracking-[0.12em] text-[var(--primary-container)]">
        Karachi<br />And Beyond
      </h1>

      <p class="mx-auto mt-8 max-w-[36rem] font-['Newsreader'] text-[1.15rem] italic leading-relaxed text-[var(--on-surface)] opacity-80">
        A celestial log of an 18-year-old aerospace aspirant mapping the path from
        the shores of Sindh to the Martian frontier.
      </p>

      <div class="mt-12">
        <a
          href="#mission-log"
          class="btn-primary inline-block bg-[var(--primary-container)] px-10 py-4 font-['Space_Mono'] text-[0.75rem] font-bold uppercase tracking-widest text-[#452b00] transition-all hover:bg-[var(--primary)]"
        >
          █ Initiate Log_Readout
        </a>
      </div>
    </div>

    <!-- Bottom-left telemetry -->
    <div class="absolute bottom-8 left-8 font-['Space_Mono'] text-[0.6rem] uppercase tracking-[0.3em] opacity-40">
      Station_ID: KHI_01 // 24.8607° N, 67.0104° E
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       SECTION 2 — FEATURED INTEL
  ═══════════════════════════════════════════════════ -->
  <section class="grid grid-cols-1 border-b border-[#31353b]/20 md:grid-cols-12">

    <!-- Left: cover image (7/12) -->
    <div class="relative h-[480px] overflow-hidden bg-[var(--surface-container)] md:col-span-7 md:h-[560px]">
      <div class="scan-lines absolute inset-0 z-10 opacity-40" aria-hidden="true"></div>

      {featuredPost?.coverImage ? (
        <img
          src={featuredPost.coverImage}
          alt={featuredPost.title}
          class="h-full w-full object-cover brightness-50 contrast-125 grayscale"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-[radial-gradient(circle_at_center,rgba(255,200,128,0.12),transparent_60%)]">
          <span class="font-['Space_Mono'] text-[0.65rem] uppercase tracking-[0.3em] text-[var(--on-surface-soft)]">No cover image</span>
        </div>
      )}

      <div class="absolute inset-0 bg-gradient-to-t from-[#0a0e14] to-transparent opacity-70"></div>

      <!-- Post info at bottom -->
      <div class="absolute bottom-10 left-10 right-10 z-20">
        <div class="mb-4 flex flex-wrap gap-3">
          <span class="border border-[rgba(47,248,1,0.3)] bg-[rgba(47,248,1,0.08)] px-3 py-1 font-['Space_Mono'] text-[0.58rem] uppercase tracking-tighter text-[var(--secondary-container)]">
            --FEATURED_INTEL
          </span>
          <span class="py-1 font-['Space_Mono'] text-[0.58rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-60">
            {featuredPost ? formatPostDate(featuredPost.date) : 'No date'} // SYNC: COMPLETE
          </span>
        </div>

        <h2 class="max-w-[20ch] font-['Space_Grotesk'] text-[clamp(1.8rem,4vw,3.2rem)] font-bold uppercase leading-[0.92] tracking-tight text-[var(--on-surface)]">
          {featuredPost?.title || 'No featured post yet'}
        </h2>
      </div>
    </div>

    <!-- Right: excerpt + READ_DATA_PACKET (5/12) -->
    <div class="flex flex-col justify-start bg-[var(--surface-container-low)] p-10 md:col-span-5 md:p-14">
      {featuredPost ? (
        <>
          <blockquote class="relative border-l-2 border-[var(--primary)] py-4 pl-6 font-['Newsreader'] text-[1.3rem] italic leading-relaxed text-[#E8E6DF]">
            {featuredPost.excerpt || 'A deep technical dive from the field terminal.'}
          </blockquote>

          <p class="mt-8 font-['Newsreader'] text-[1.05rem] leading-[1.8] text-[var(--on-surface)] opacity-70">
            A deep-dive from the mission archive. Telemetry compiled and transmitted
            from the Karachi field station.
          </p>

          <a
            href={`/${featuredPost.slug}`}
            class="mt-10 font-['Space_Mono'] text-[0.8rem] uppercase tracking-[0.2em] text-[var(--primary)] transition-all hover:underline"
          >
            &gt; READ_DATA_PACKET.PDF
          </a>

          <a
            href={`/${featuredPost.slug}`}
            class="btn-primary mt-6 inline-flex items-center gap-3 border border-[rgba(255,200,128,0.3)] bg-[rgba(255,200,128,0.1)] px-5 py-3 font-['Space_Grotesk'] text-[0.7rem] uppercase tracking-[0.22em] text-[var(--primary)] transition hover:bg-[rgba(255,200,128,0.18)]"
          >
            <span>Open data packet</span>
            <span>→</span>
          </a>
        </>
      ) : (
        <p class="font-['Newsreader'] text-[1rem] leading-7 text-[var(--on-surface-soft)]">
          Flag a post with <code class="text-[var(--primary)]">featured: true</code> to surface it here.
        </p>
      )}
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       SECTION 3 — MISSION LOGS + ABOUT THE PILOT
  ═══════════════════════════════════════════════════ -->
  <section class="mt-20 grid grid-cols-1 border-t border-[#31353b]/20 lg:grid-cols-12">

    <!-- Left: Mission Logs (8/12) -->
    <div id="mission-log" class="border-b border-[#31353b]/20 p-8 md:p-14 lg:col-span-8 lg:border-b-0 lg:border-r lg:border-[#31353b]/20">
      <!-- Section header -->
      <header class="mb-14 flex items-baseline justify-between gap-6">
        <h3 class="font-['Space_Mono'] text-[1rem] uppercase tracking-[0.2em] text-[var(--primary)] whitespace-nowrap">
          // Mission Logs
        </h3>
        <div class="mx-4 h-px flex-grow self-center bg-[#31353b]/30"></div>
        <div class="flex gap-6 font-['Space_Mono'] text-[0.58rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50 whitespace-nowrap">
          <span>Entries: {entryCount}</span>
          <span>Status: Live</span>
        </div>
      </header>

      <!-- Log entries -->
      <div class="space-y-14">
        {recentPosts.map((post, index) => (
          <article class="log-entry group relative border-l border-[#31353b]/30 pl-10 transition-all duration-300 hover:border-l-[var(--primary)]">
            <!-- Amber gutter accent -->
            <div class="log-entry-gutter"></div>

            <!-- Meta row -->
            <div class="mb-4 flex flex-wrap items-baseline gap-4">
              <span class="font-['Space_Mono'] text-[0.65rem] uppercase text-[var(--secondary-container)]">
                Log_{String(index + 1).padStart(3, '0')}
              </span>
              <span class="font-['Space_Mono'] text-[0.58rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50">
                {formatPostDate(post.date)}
              </span>
            </div>

            <!-- Title -->
            <a href={`/${post.slug}`} class="block">
              <h4 class="max-w-[22ch] font-['Space_Grotesk'] text-[clamp(1.8rem,4vw,3.2rem)] font-bold uppercase leading-[0.9] tracking-tight text-[var(--on-surface)] transition-colors duration-200 group-hover:text-[var(--primary)]">
                {post.title}
              </h4>
            </a>

            <!-- Excerpt -->
            <p class="mt-4 max-w-[48rem] font-['Newsreader'] text-[1.05rem] leading-[1.8] text-[var(--on-surface)] opacity-75">
              {post.excerpt || 'Telemetry received. Details are being compiled from the archives.'}
            </p>

            <!-- Tag badges -->
            <div class="mt-5 flex flex-wrap gap-3">
              <span class="border border-[#31353b]/40 px-2 py-1 font-['Space_Mono'] text-[0.58rem] uppercase tracking-tighter text-[var(--on-surface-soft)] opacity-60 transition-colors hover:border-[var(--secondary)] hover:text-[var(--secondary)] cursor-crosshair">
                [--{post.category}]
              </span>
              {post.featured && (
                <span class="border border-[rgba(47,248,1,0.3)] px-2 py-1 font-['Space_Mono'] text-[0.58rem] uppercase tracking-tighter text-[var(--secondary-container)] cursor-crosshair">
                  [--featured]
                </span>
              )}
            </div>
          </article>
        ))}

        <!-- View all logs link -->
        <a
          href="/journal"
          class="mt-4 inline-flex items-center gap-3 border border-[rgba(255,200,128,0.18)] px-4 py-3 font-['Space_Grotesk'] text-[0.68rem] uppercase tracking-[0.22em] text-[var(--primary)] transition hover:bg-[rgba(255,200,128,0.08)]"
        >
          <span>View all logs</span>
          <span>→</span>
        </a>
      </div>
    </div>

    <!-- Right: About The Pilot (4/12) -->
    <aside class="bg-[var(--surface-container-low)] p-8 md:p-14 lg:col-span-4">
      <header class="mb-14">
        <h3 class="font-['Space_Mono'] text-[1rem] uppercase tracking-[0.2em] text-[var(--primary)]">
          &gt; About The Pilot
        </h3>
      </header>

      <div class="space-y-10">
        <!-- Bio copy -->
        <p class="font-['Newsreader'] text-[1.1rem] leading-[1.8] text-[#E8E6DF]">
          I am an 18-year-old student currently deciphering the complexities of
          orbital mechanics from a small desk in Gulshan. My mission is to bridge
          the gap between Karachi's industrial grit and the infinite potential of
          aerospace engineering. This blog is my telemetry data.
        </p>

        <!-- Stats data panels -->
        <div class="border-t border-[#31353b]/30 pt-10">
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-[var(--surface-container)] p-4">
              <p class="font-['Space_Mono'] text-[0.55rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50">Age</p>
              <p class="mt-1 font-['Space_Mono'] text-[0.9rem] text-[var(--secondary-container)]">18_Earth_Years</p>
            </div>
            <div class="bg-[var(--surface-container)] p-4">
              <p class="font-['Space_Mono'] text-[0.55rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50">Status</p>
              <p class="mt-1 font-['Space_Mono'] text-[0.9rem] text-[var(--secondary-container)]">Aspirant</p>
            </div>
            <div class="col-span-2 bg-[var(--surface-container)] p-4">
              <p class="font-['Space_Mono'] text-[0.55rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50">Mission_Objective</p>
              <p class="mt-1 font-['Space_Mono'] text-[0.9rem] uppercase text-[var(--primary)]">Aerospace Engineering</p>
            </div>
            <div class="col-span-2 bg-[var(--surface-container)] p-4">
              <p class="font-['Space_Mono'] text-[0.55rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-50">Coordinates</p>
              <p class="mt-1 font-['Space_Mono'] text-[0.9rem] text-[#E8E6DF]">24.8607° N, 67.0104° E</p>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </section>


  <!-- ══════════════════════════════════════════════════
       SECTION 4 — INTEL ARCHIVE (Currently Reading/Watching)
  ═══════════════════════════════════════════════════ -->
  <section class="border-t border-[#31353b]/20 p-8 md:p-14 lg:grid lg:grid-cols-12 lg:gap-10">

    <!-- Header column -->
    <div class="mb-10 lg:col-span-4 lg:mb-0">
      <p class="font-['Space_Mono'] text-[0.6rem] uppercase tracking-[0.48em] text-[var(--secondary)]">Currently reading / watching</p>
      <h2 class="mt-3 font-['Space_Grotesk'] text-[clamp(2rem,4vw,3.2rem)] font-bold uppercase leading-[0.9] tracking-[-0.04em] text-[var(--on-surface)]">
        Intel Archive
      </h2>
      <p class="mt-4 max-w-[26rem] font-['Newsreader'] text-[0.98rem] leading-7 text-[var(--on-surface-soft)]">
        Books and films tracked through the Intel collection. Status and progress
        logged from the field station.
      </p>
    </div>

    <!-- Cards column -->
    <div class="grid gap-4 lg:col-span-8 sm:grid-cols-2">
      {intelItems.length > 0 ? (
        intelItems.map((entry: any) => {
          const progress = entry.status === 'complete' ? 100 : 42;
          const image = entry.coverImage || '/images/posts/test-post/coverImage.jpg';
          return (
            <article class="grid gap-4 border border-[#31353b]/30 bg-[var(--surface-container-low)] p-4 transition hover:border-[rgba(255,200,128,0.3)] sm:grid-cols-[120px_minmax(0,1fr)]">
              <!-- Cover -->
              <div class="overflow-hidden border border-[#31353b]/30 bg-[var(--surface-container)]">
                <img src={image} alt={entry.title} class="h-full min-h-[140px] w-full object-cover opacity-90" />
              </div>
              <!-- Info -->
              <div>
                <div class="flex flex-wrap items-center gap-2 font-['Space_Mono'] text-[0.56rem] uppercase tracking-[0.18em]">
                  <span class="border border-[rgba(215,255,197,0.2)] px-2 py-1 text-[var(--secondary)]">{entry.itemType}</span>
                  <span class="text-[var(--on-surface-soft)] opacity-60">{entry.creator || 'Unknown'}</span>
                </div>
                <h3 class="mt-3 font-['Space_Grotesk'] text-[1.25rem] font-semibold uppercase leading-[1.04] text-[var(--on-surface)]">{entry.title}</h3>
                <p class="mt-2 font-['Newsreader'] text-[0.9rem] leading-6 text-[var(--on-surface-soft)]">{entry.excerpt || 'Status tracked from the archive.'}</p>
                <!-- Progress bar -->
                <div class="mt-4">
                  <div class="mb-1.5 flex items-center justify-between font-['Space_Mono'] text-[0.54rem] uppercase tracking-[0.18em] text-[var(--on-surface-soft)] opacity-60">
                    <span>Progress</span>
                    <span>{progress}%</span>
                  </div>
                  <div class="h-1 bg-[rgba(255,255,255,0.05)]">
                    <div class="h-1 bg-[var(--primary)] transition-all" style={`width:${progress}%`}></div>
                  </div>
                </div>
                <!-- Rating / Status badges -->
                <div class="mt-4 flex flex-wrap gap-2 font-['Space_Mono'] text-[0.54rem] uppercase tracking-[0.18em]">
                  <span class="border border-[rgba(255,200,128,0.2)] px-2 py-1 text-[var(--primary)]">{entry.rating || 'N/A'}</span>
                  <span class="border border-[rgba(215,255,197,0.2)] px-2 py-1 text-[var(--secondary)]">{entry.status}</span>
                </div>
              </div>
            </article>
          );
        })
      ) : (
        <div class="border border-[#31353b]/30 bg-[var(--surface-container-low)] p-6 font-['Space_Mono'] text-[0.72rem] uppercase tracking-[0.2em] text-[var(--on-surface-soft)]">
          No Intel entries yet. Add items to the intel collection.
        </div>
      )}
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       SECTION 5 — ACQUIRED GEAR AND FINDS
  ═══════════════════════════════════════════════════ -->
  <section class="border-t border-[#31353b]/20 p-8 md:p-14 lg:grid lg:grid-cols-12 lg:gap-10">

    <!-- Header column -->
    <div class="mb-10 lg:col-span-4 lg:mb-0">
      <p class="font-['Space_Mono'] text-[0.6rem] uppercase tracking-[0.48em] text-[var(--secondary)]">Acquired gear and finds</p>
      <h2 class="mt-3 font-['Space_Grotesk'] text-[clamp(2rem,4vw,3.2rem)] font-bold uppercase leading-[0.9] tracking-[-0.04em] text-[var(--on-surface)]">
        Field Inventory
      </h2>
      <p class="mt-4 max-w-[26rem] font-['Newsreader'] text-[0.98rem] leading-7 text-[var(--on-surface-soft)]">
        A quieter shelf — older entries and useful discoveries pulled directly
        from the post archive.
      </p>
    </div>

    <!-- Cards grid column -->
    <div class="grid gap-4 sm:grid-cols-2 lg:col-span-8 xl:grid-cols-3">
      {gearPosts.length > 0 ? (
        gearPosts.map((post) => (
          <a
            href={`/${post.slug}`}
            class="group overflow-hidden border border-[#31353b]/30 bg-[var(--surface-container-low)] transition hover:border-[rgba(255,200,128,0.3)] hover:bg-[var(--surface-container)]"
          >
            <!-- Cover image -->
            <div class="relative h-44 overflow-hidden bg-[var(--surface-container)]">
              {post.coverImage ? (
                <img
                  src={post.coverImage}
                  alt={post.title}
                  class="h-full w-full object-cover opacity-85 transition duration-300 group-hover:scale-[1.03]"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-[radial-gradient(circle_at_center,rgba(255,200,128,0.1),transparent_60%)]">
                  <span class="font-['Space_Mono'] text-[0.58rem] uppercase tracking-widest text-[var(--on-surface-soft)] opacity-40">No image</span>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[#12161b] to-transparent opacity-80"></div>
            </div>

            <!-- Card body -->
            <div class="p-4">
              <div class="flex items-center justify-between gap-3 font-['Space_Mono'] text-[0.55rem] uppercase tracking-[0.18em] text-[var(--on-surface-soft)] opacity-60">
                <span>--{post.category}</span>
                <span>{formatPostDate(post.date)}</span>
              </div>
              <h3 class="mt-3 font-['Space_Grotesk'] text-[1.2rem] font-semibold uppercase leading-[1.04] text-[var(--on-surface)] transition group-hover:text-[var(--primary)]">
                {post.title}
              </h3>
              <p class="mt-2 font-['Newsreader'] text-[0.9rem] leading-6 text-[var(--on-surface-soft)]">
                {post.excerpt || 'Archived item from the same field log.'}
              </p>
              <div class="mt-4 flex items-center justify-between font-['Space_Mono'] text-[0.56rem] uppercase tracking-[0.18em] text-[var(--on-surface-soft)] opacity-60">
                <span>{post.readTime || '5 MIN READ'}</span>
                <span class="text-[var(--primary)] opacity-100">Inspect →</span>
              </div>
            </div>
          </a>
        ))
      ) : (
        <div class="border border-[#31353b]/30 bg-[var(--surface-container-low)] p-6 font-['Space_Mono'] text-[0.72rem] uppercase tracking-[0.2em] text-[var(--on-surface-soft)]">
          No additional posts available yet.
        </div>
      )}
    </div>
  </section>

</MainLayout>