---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecentPostCard from '../../components/RecentPostCard.astro';
import { getCollection } from 'astro:content';

const { category } = Astro.params;

const CATEGORIES: Record<string, string> = {
  philosophy: 'Philosophy',
  science: 'Science',
  thoughts: 'Thoughts',
  miscellaneous: 'Miscellaneous',
};

const title = category ? CATEGORIES[category as string] || category : 'Category';

const _allPosts = await getCollection('posts');
const posts = _allPosts
  .filter((post) => post.data.category === category)
  .map(p => ({ slug: p.slug, ...p.data }));

---

<MainLayout title={`${title} - The Wandering Mind`}>
  <Header />

  <main class="container" style="padding-top: 60px; padding-bottom: 80px; min-height: 60vh;">
    <h1 class="category-page-title">
      <span class="muted">Category:</span> {title}
    </h1>

    {posts.length > 0 ? (
      <div class="cards-grid">
        {posts.map((post: any) => {
          const catName = CATEGORIES[post.category] || 'General';
          return (
            <RecentPostCard
              title={post.title}
              slug={post.slug}
              excerpt={post.excerpt}
              coverImage={post.coverImage}
              categoryName={catName}
              categorySlug={post.category}
              authorName={post.authorName}
              readTime={post.readTime}
            />
          );
        })}
      </div>
    ) : (
      <div class="no-posts">
        <p>No posts found in this category yet. Check back soon!</p>
      </div>
    )}
  </main>

  <Footer />
</MainLayout>

<style>
  .category-page-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 48px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 24px;
  }
  
  .category-page-title .muted {
    color: var(--text-muted);
    font-size: 1.5rem;
    font-weight: 500;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  
  .no-posts {
    padding: 60px 0;
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
  }

  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
    .category-page-title {
      font-size: 2rem;
    }
  }
</style>
