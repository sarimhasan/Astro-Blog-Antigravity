---
/**
 * MainLayout Component
 * The base template for all pages in the blog.
 * Handles the common HTML structure, meta tags, global styling, and theme management.
 */
interface Props {
  title?: string; // Optinal page title
}

const { title = "The Wandering Mind" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Sarim's Pensieve — A Thinking Space" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Font Preconnections for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Fonts: Outfit for body, Playfair Display for headings -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
  </head>
  <body>
    <!-- Main page content is injected here via the slot -->
    <slot />

    <script is:inline>
      /**
       * Theme Management Script
       * Handles switching between Light and Dark modes.
       * Uses 'data-theme' attribute on <html> for CSS targeting.
       * Persists user preference in localStorage.
       */
      
      // Initialize theme from localStorage or default to 'light'
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);

      // Global function to toggle theme, accessible from components
      window.toggleTheme = function() {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        
        // Update document and storage
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);

        // Update the visual state of the theme toggle button if it exists
        const btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.innerHTML = next === 'dark'
            ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg> Light'
            : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg> Dark';
        }
      };
    </script>
  </body>
</html>

<style is:global>
  /* Import global CSS variables and reset */
  @import '../styles/global.css';
</style>

