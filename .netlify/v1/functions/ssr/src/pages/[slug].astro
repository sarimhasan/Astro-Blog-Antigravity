---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getEntry } from 'astro:content';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const post = await getEntry('posts', slug);

if (!post) {
  return Astro.redirect('/');
}

const { Content } = await post.render();

const CATEGORIES: Record<string, string> = {
  philosophy: 'Philosophy',
  science: 'Science',
  thoughts: 'Thoughts',
  miscellaneous: 'Miscellaneous',
};

const categoryName = CATEGORIES[post.data.category] || 'General';

const dateStr = new Date().toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const initials = post.data.authorName
  ? post.data.authorName.split(' ').map((w: string) => w[0]).join('')
  : '?';
---

<MainLayout title={`${post.data.title} — The Wandering Mind`}>
  <Header />

  <article class="post-page container">
    <a href="/" class="post-page__back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to Home
    </a>

    <div class="post-page__meta">
      <CategoryBadge name={categoryName} slug={post.data.category} />
      <span class="post-page__read-time">{post.data.readTime}</span>
    </div>

    <h1 class="post-page__title">{post.data.title}</h1>
    <p class="post-page__excerpt">{post.data.excerpt}</p>

    {post.data.coverImage && <img src={post.data.coverImage} alt={post.data.title} class="post-page__cover" />}

    <div class="post-page__author">
      <div class="post-page__author-avatar">{initials}</div>
      <div class="post-page__author-info">
        <span class="post-page__author-name">{post.data.authorName}</span>
        <span class="post-page__author-date">{dateStr} · {post.data.readTime}</span>
      </div>
    </div>

    <div class="post-content">
      <Content />
    </div>
  </article>

  <Footer />
</MainLayout>

<style>
  .post-page {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .post-page__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 40px;
    transition: color 0.2s;
  }

  .post-page__back:hover {
    color: var(--text-primary);
  }

  .post-page__meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .post-page__read-time {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .post-page__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: 20px;
    max-width: 800px;
  }

  .post-page__excerpt {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 720px;
    margin-bottom: 40px;
  }

  .post-page__cover {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: 40px;
  }

  .post-page__author {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 48px;
    padding: 20px 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .post-page__author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--text-primary);
    color: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .post-page__author-name {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
  }

  .post-page__author-date {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .post-content {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    font-family: var(--font-heading);
    color: var(--text-primary);
    margin: 2rem 0 1rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.4rem;
  }

  .post-content :global(a) {
    color: var(--text-primary);
    text-decoration: underline;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-sm);
    margin: 1.5rem 0;
  }

  .post-content :global(code) {
    background: var(--bg-secondary);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.88em;
  }

  .post-content :global(pre) {
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
</style>
